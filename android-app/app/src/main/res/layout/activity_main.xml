<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <!-- Camera preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:scaleType="fillCenter" />

    <!-- Polygon overlay drawn on top of camera feed -->
    <com.dcops.ar.overlay.PolygonOverlayView
        android:id="@+id/overlayView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Backend toggle + metrics at top -->
    <LinearLayout
        android:id="@+id/metricsBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#AA000000"
        android:padding="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/backendLabel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="XNNPACK (CPU)"
            android:textColor="#00E676"
            android:textSize="13sp"
            android:fontFamily="monospace" />

        <TextView
            android:id="@+id/fpsText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-- FPS"
            android:textColor="#FFEB3B"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:paddingEnd="12dp" />

        <TextView
            android:id="@+id/latencyText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--ms"
            android:textColor="#FFEB3B"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:paddingEnd="12dp" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/backendSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NPU"
            android:textColor="@color/white"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Status bar at the bottom -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/status_bg"
        android:padding="12dp"
        android:text="@string/status_waiting"
        android:textColor="@color/white"
        android:textSize="14sp"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>